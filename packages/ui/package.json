{
  "name": "@aster-cloud/ui",
  "version": "0.3.0",
  "description": "Aster React UI primitives. Built on @aster-cloud/tokens. Consumed by aster-cloud.",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aster-cloud/aster-design-system.git",
    "directory": "packages/ui"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src",
    "!src/**/*.stories.*",
    "!src/**/*.test.*",
    "!src/**/*.spec.*",
    "!src/**/__tests__/**"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "sonner": "^2.0.0 || ^1.5.0"
  },
  "peerDependenciesMeta": {
    "sonner": {
      "optional": true
    }
  },
  "dependencies": {
    "@aster-cloud/tokens": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.18.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.7.0",
    "jsdom": "^25.0.1",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "sonner": "^2.0.0",
    "typescript": "^5.6.0",
    "vitest": "^3.2.4"
  }
}
