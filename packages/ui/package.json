{
  "name": "@aster-cloud/ui",
  "version": "0.2.0",
  "description": "Aster React UI primitives. Built on @aster-cloud/tokens. Consumed by aster-cloud.",
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aster-cloud/aster-design-system.git",
    "directory": "packages/ui"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "peerDependencies": {
    "react": "^18.2.0 || ^19.0.0",
    "sonner": "^2.0.0 || ^1.5.0"
  },
  "peerDependenciesMeta": {
    "sonner": { "optional": true }
  },
  "dependencies": {
    "@aster-cloud/tokens": "workspace:*",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.460.0",
    "tailwind-merge": "^2.5.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "react": "^18.3.0",
    "sonner": "^2.0.0",
    "typescript": "^5.6.0"
  }
}
